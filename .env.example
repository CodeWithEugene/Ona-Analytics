# AWS Aurora PostgreSQL (via Vercel OIDC integration — no password needed)
# Override PGHOST in production with your actual RDS cluster endpoint
PGHOST=YOUR_PGHOST
PGPORT=5432
PGUSER=postgres
PGDATABASE=postgres
PGSSLMODE=require
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/Vercel/access-apg-YOUR_CLUSTER
AWS_RESOURCE_ARN=arn:aws:rds:us-east-1:YOUR_ACCOUNT:cluster:YOUR_CLUSTER
AWS_ACCOUNT_ID=YOUR_ACCOUNT

# Local development (set PGPASSWORD when not using Vercel OIDC)
# PGPASSWORD=your_local_postgres_password

# Auth
# openssl rand -base64 32
AUTH_SECRET=""
# Override AUTH_URL in production with your deployed domain
AUTH_URL=http://localhost:3000

# NVIDIA Nemotron (for the Ona Agent)
# Get your API key from https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# Admin
# Comma-separated list of admin emails allowed to run migrations
ADMIN_EMAILS=admin@ona-analytics.com

# Setup API key (for creating users without registration)
# openssl rand -base64 32
SETUP_API_KEY=""

# App
# Override NEXT_PUBLIC_APP_URL in production with your deployed domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monitoring (optional — uncomment when ready)
# SENTRY_DSN=https://...
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Email (optional — required for password reset emails)
# RESEND_API_KEY=re_...
